---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Carnegie Shoes" description="The page you're looking for doesn't exist. Head back home or explore our brands and services.">
  <section class="max-w-screen-2xl mx-auto px-8 md:px-12 py-32 min-h-[60vh] flex flex-col justify-center">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7">
        <span class="font-label text-sm tracking-[0.3em] uppercase text-primary font-bold mb-6 block">Error 404</span>
        <h1 class="font-headline text-6xl md:text-9xl font-black tracking-tighter uppercase leading-[0.85] mb-8 text-mosaic">
          Wrong<br/><span class="text-primary">Footing.</span>
        </h1>
        <p class="font-body text-xl text-on-surface-variant max-w-md mb-12">
          The page you're looking for has walked off. Let's get you back on track.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/" class="bg-primary text-on-primary px-8 py-4 font-headline font-bold uppercase tracking-tighter rounded-lg hover:bg-stone-800 transition-colors inline-block">
            Return Home
          </a>
          <a href="/contact" class="bg-on-surface text-surface px-8 py-4 font-headline font-bold uppercase tracking-tighter rounded-lg hover:opacity-90 transition-all inline-block">
            Contact Us
          </a>
        </div>
      </div>
      <div class="md:col-span-5">
        <div class="bg-tertiary-container p-12 rounded-xl shadow-xl -rotate-2">
          <div class="font-headline text-[10rem] leading-none font-black text-on-tertiary-container text-center">404</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
