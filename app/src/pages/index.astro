---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carnegie Shoes | The Kinetic Mosaic">
  <section class="relative max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0 relative">
      <!-- Large Display Image -->
      <div class="md:col-span-8 h-[716px] relative overflow-hidden bg-surface-container-low">
        <img class="w-full h-full object-cover" alt="Stylish energetic sneakers" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDUatwWNRBqNHqNRk9MNUIKSVoxmYgVT391VU9FfVcByAlJsfUm6nXKnumi2XXd5bNI_vys0vg-H1qYznHViNIMfCJzDOWD9iOiF0XreVijVeo21F-7jUKA5FDyvD6WHpGzfYW1NgZagcq7l-IT_kFI2FBVf1xPdejFYrqhwndW1gBIP73E225Ncn2P8sh_rT0UyHzAg0wa1XLlZTZyqGJYtWyRROfkAsLQloCi6anqwS4CHIJqEj9crzVBTW2nnkCVOI_-1NvhSg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-tertiary/20 to-transparent"></div>
      </div>
      <!-- Overlapping Text Block -->
      <div class="md:col-span-6 md:absolute md:right-0 md:bottom-[-4rem] bg-tertiary-container p-12 md:p-16 z-10 shadow-[48px_48px_48px_-4px_rgba(0,101,111,0.12)]">
        <span class="font-label text-on-tertiary-container uppercase tracking-widest text-sm mb-4 block">Est. 1974 — Local & Family Owned</span>
        <h1 class="font-headline text-5xl md:text-7xl font-black text-on-tertiary-container mb-6 leading-[0.9] text-mosaic">
            STEP INTO THE <br/>KINETIC MOSAIC
        </h1>
        <p class="text-on-tertiary-container text-lg md:text-xl max-w-md font-medium leading-relaxed mb-8">
            Carnegie Shoes is a small, well-established family business fitting and selling shoes for everyone from kids to seniors.
        </p>
        <div class="flex gap-4">
          <a href="/brands" class="bg-primary text-on-primary px-8 py-4 font-headline font-bold uppercase tracking-tighter rounded-lg hover:bg-stone-800 transition-colors inline-block">
              Explore Collections
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Neighborhood Vibe (Bento Grid) -->
  <section class="max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div>
        <h2 class="font-headline text-4xl md:text-6xl font-black tracking-tighter uppercase text-primary">Made for Movement</h2>
        <p class="font-label uppercase tracking-widest text-secondary mt-2">The Carnegie neighborhood energy</p>
      </div>
      <div class="h-px flex-grow bg-surface-container hidden md:block mx-12 mb-4"></div>
      <div class="font-body text-on-surface-variant max-w-xs text-right">
          From children's first steps to senior strolls, we weave quality into every corner of our community.
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-4 h-auto md:h-[800px]">
      <!-- Large Focus Card -->
      <div class="md:col-span-2 md:row-span-2 bg-surface-container-low relative group overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="Neighborhood energy" src="https://lh3.googleusercontent.com/aida/ADBb0ujRzPosvMvJsYq6zXyDCwJT5c0NzgzFfGARBfr0uUGrI0fRsoqhhV8jRmZ9PfxZoU7l2qvO5HKJZ5zzcD3Uxohtt6IHs3v-FPhIc9_QYvPKxMF_-OH4fu2Nmi6mr4bFCNqGxzG5A2lbnimzgqq8QmgWwoaK5wK2FOyDPw2pLQHQSbrJv_DqxUqfBrk9rPFsvd7C5f5pOalKZJyhC6DXtgKE_lqagGopEcErRllATx6lUBpUBM4ATIRVlL4yyIUt6s1Fnfv9qBI"/>
        <div class="absolute inset-0 bg-primary/20 group-hover:bg-transparent transition-colors"></div>
        <div class="absolute bottom-0 left-0 p-8 text-white z-10">
          <span class="bg-primary px-3 py-1 font-label text-xs uppercase mb-2 inline-block">The Foundation</span>
          <h3 class="font-headline text-3xl font-black uppercase leading-none">Family Heritage</h3>
        </div>
      </div>
      
      <!-- Kids Segment -->
      <div class="md:col-span-2 bg-secondary-container p-8 flex flex-col justify-between relative overflow-hidden">
        <div class="z-10">
          <h3 class="font-headline text-4xl font-black text-on-secondary-container leading-none mb-4 uppercase">Little <br/>Legends</h3>
          <p class="font-body text-on-secondary-container max-w-xs">Durable, vibrant footwear for the smallest members of our neighborhood.</p>
        </div>
        <div class="flex justify-end z-10">
          <span class="material-symbols-outlined text-6xl text-on-secondary-container opacity-30">child_care</span>
        </div>
        <div class="absolute -right-8 -bottom-8 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
      </div>
      
      <!-- Senior Comfort -->
      <div class="bg-surface-container-highest p-8 flex flex-col justify-between hover:bg-tertiary group transition-colors">
        <div>
          <span class="material-symbols-outlined text-4xl mb-4 group-hover:text-tertiary-container transition-colors">nordic_walking</span>
          <h3 class="font-headline text-xl font-bold uppercase group-hover:text-white transition-colors">Golden Years Comfort</h3>
        </div>
        <a href="/services" class="font-label text-sm uppercase font-bold group-hover:text-tertiary-container transition-colors flex items-center gap-2">
            View Orthotics <span class="material-symbols-outlined text-xs">arrow_forward</span>
        </a>
      </div>
      
      <!-- Community Event -->
      <div class="bg-primary-container p-8 flex flex-col justify-between">
        <div class="font-headline text-on-primary-container">
          <div class="text-4xl font-black">20%</div>
          <div class="text-lg font-bold uppercase leading-tight">Local Business Discount</div>
        </div>
        <p class="font-body text-sm text-on-primary-container/80">Support local, save local. Available for Carnegie residents.</p>
      </div>
    </div>
  </section>

  <!-- Personalized Fitting Section -->
  <section class="max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="bg-on-background p-12 md:p-24 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="z-10 max-w-2xl">
        <h2 class="font-headline text-5xl md:text-6xl font-black text-surface tracking-tighter leading-none mb-8">
            PRECISION <br/><span class="text-primary">FOOTWEAR FITTING</span>
        </h2>
        <p class="text-surface-variant font-body text-xl md:text-2xl font-medium leading-relaxed">
            Each customer gets an attentive and personalised service from our highly qualified shoe fitters.
        </p>
        <div class="mt-12">
          <a href="/services" class="bg-primary text-on-primary font-headline font-bold px-10 py-5 uppercase tracking-tighter hover:bg-stone-800 transition-all rounded-lg inline-block">Book a Fitting</a>
        </div>
      </div>
      <div class="w-full md:w-2/5 aspect-[4/5] bg-surface-container-low rounded-lg -rotate-1 shadow-2xl relative z-10 overflow-hidden">
        <img class="w-full h-full object-cover" alt="Professional shoe fitting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3CvT3vDk74EJ_3NIleF7ltjUwfuX9R0GDH1sNF6qppdkj4ZvovLrBAwt10JuSqroQv1qvIx-5Z1NieEv2czodAEbsAV2xC6xhF5h37O86qCe_dHEAodprGR5H5i9ZltYbRn4cuAfIQhcJpru4USh4tKSGOTTFJ96MiufGWRb-czDPZifpuDCwrWo6QU8Xa5Fs5cNIP7DZx9Vc6iWJXJ1ScyA2jHRc_MchaEkEEKqMAZ-NOozM1-XZ94hnDSDjwQT_XefZa69d4A"/>
      </div>
      <!-- Decorative element -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary opacity-10 blur-[120px] -mr-48 -mt-48"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-tertiary opacity-10 blur-[100px] -ml-32 -mb-32"></div>
    </div>
  </section>
</Layout>
