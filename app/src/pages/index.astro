---
import Layout from '../layouts/Layout.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ShoeStore",
  "name": "Carnegie Shoes",
  "image": "https://carnegieshoes.com.au/hero_lifestyle_1776061010416.png",
  "@id": "https://carnegieshoes.com.au",
  "url": "https://carnegieshoes.com.au",
  "telephone": "(03) 9571 5203",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "119 Koornang Road",
    "addressLocality": "Carnegie",
    "addressRegion": "VIC",
    "postalCode": "3163",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -37.8876412,
    "longitude": 145.0566276
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "14:00"
    }
  ],
  "sameAs": []
};
---

<Layout title="Carnegie Shoes | Family Shoe Store in Carnegie" description="Since 2014, Carnegie Shoes provides precision footwear fitting & orthotics. Durable, comfortable brands for infants, adults, and seniors in Carnegie VIC." structuredData={localBusinessSchema}>
  <section class="relative max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0 relative">
      <!-- Large Display Image -->
      <div class="md:col-span-8 h-[716px] relative overflow-hidden bg-surface-container-low">
        <img class="w-full h-full object-cover" fetchpriority="high" decoding="async" alt="Stylish energetic sneakers" src="/images/IMG_3776.jpeg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-tertiary/20 to-transparent"></div>
      </div>
      <!-- Overlapping Text Block -->
      <div class="md:col-span-6 md:absolute md:right-0 md:bottom-[-4rem] bg-tertiary-container p-12 md:p-16 z-10 shadow-[48px_48px_48px_-4px_rgba(0,101,111,0.12)]">
        <span class="font-label text-on-tertiary-container uppercase tracking-widest text-sm mb-4 block">Est. 2014 — Local & Family Owned</span>
        <h1 class="font-headline text-5xl md:text-7xl font-black text-on-tertiary-container mb-6 leading-[0.9] text-mosaic">
            STEP INTO THE <br/>KINETIC MOSAIC
        </h1>
        <p class="text-on-tertiary-container text-lg md:text-xl max-w-md font-medium leading-relaxed mb-8">
            Carnegie Shoes is a small, well-established family business fitting and selling shoes for everyone from kids to seniors.
        </p>
        <div class="flex gap-4">
          <a href="/brands" class="bg-primary text-on-primary px-8 py-4 font-headline font-bold uppercase tracking-tighter rounded-lg hover:bg-stone-800 transition-colors inline-block" aria-label="Explore our shoe collections">
              Explore Collections
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Neighborhood Vibe (Bento Grid) -->
  <section class="max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div>
        <h2 class="font-headline text-4xl md:text-6xl font-black tracking-tighter uppercase text-primary">Made for Movement</h2>
        <p class="font-label uppercase tracking-widest text-secondary mt-2">The Carnegie neighborhood energy</p>
      </div>
      <div class="h-px flex-grow bg-surface-container hidden md:block mx-12 mb-4"></div>
      <div class="font-body text-on-surface-variant max-w-xs text-right">
          From children's first steps to senior strolls, we weave quality into every corner of our community.
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-4 h-auto md:h-[800px]">
      <!-- Large Focus Card -->
      <div class="md:col-span-2 md:row-span-2 bg-surface-container-low relative group overflow-hidden">
        <img loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="Neighborhood energy" src="/images/IMG_3784.jpeg"/>
        <div class="absolute inset-0 bg-primary/20 group-hover:bg-transparent transition-colors"></div>
        <div class="absolute bottom-0 left-0 p-8 text-white z-10">
          <span class="bg-primary px-3 py-1 font-label text-xs uppercase mb-2 inline-block">The Foundation</span>
          <h3 class="font-headline text-3xl font-black uppercase leading-none">Family Heritage</h3>
        </div>
      </div>
      
      <!-- Kids Segment -->
      <div class="md:col-span-2 bg-secondary-container p-8 flex flex-col justify-between relative overflow-hidden group">
        <!-- Hover Image -->
        <img loading="lazy" decoding="async" src="/hover_kids.png" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0" alt="Kid trying shoes" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
        <!-- Content -->
        <div class="z-10 relative">
          <h3 class="font-headline text-4xl font-black text-on-secondary-container group-hover:text-white transition-colors duration-500 leading-none mb-4 uppercase">Little <br/>Legends</h3>
          <p class="font-body text-on-secondary-container group-hover:text-stone-200 transition-colors duration-500 max-w-xs">Durable, vibrant footwear for the smallest members of our neighborhood.</p>
        </div>
        <div class="flex justify-end z-10 relative">
          <span class="material-symbols-outlined text-6xl text-on-secondary-container opacity-30 group-hover:text-white group-hover:opacity-80 transition-all duration-500" aria-hidden="true">child_care</span>
        </div>
        <div class="absolute -right-8 -bottom-8 w-48 h-48 bg-primary/10 rounded-full blur-3xl z-0 group-hover:opacity-0 transition-opacity duration-500"></div>
      </div>
      
      <!-- Senior Comfort -->
      <div class="bg-surface-container-highest p-8 flex flex-col justify-between group transition-colors relative overflow-hidden">
        <!-- Hover Image -->
        <img loading="lazy" decoding="async" src="/hover_senior.png" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0" alt="Senior comfort" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
        <!-- Content -->
        <div class="z-10 relative">
          <span class="material-symbols-outlined text-4xl mb-4 group-hover:text-white transition-colors duration-500" aria-hidden="true">nordic_walking</span>
          <h3 class="font-headline text-xl font-bold uppercase group-hover:text-white transition-colors duration-500">Golden Years Comfort</h3>
        </div>
        <a href="/brands#care" class="font-label text-sm uppercase font-bold text-on-surface group-hover:text-white transition-colors duration-500 flex items-center gap-2 z-10 relative" aria-label="View our senior and orthotic offerings">
            View Range <span class="material-symbols-outlined text-xs" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
      
      <!-- Community Event -->
      <div class="bg-primary-container p-8 flex flex-col justify-between relative overflow-hidden group">
        <!-- Hover Image -->
        <img loading="lazy" decoding="async" src="/hover_discount.png" class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0" alt="Local business discount" />
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
        <!-- Content -->
        <div class="font-headline text-on-primary-container group-hover:text-white transition-colors duration-500 z-10 relative">
          <div class="text-4xl font-black">20%</div>
          <div class="text-lg font-bold uppercase leading-tight">Local Business Discount</div>
        </div>
        <p class="font-body text-sm text-on-primary-container/80 group-hover:text-stone-200 transition-colors duration-500 z-10 relative">Support local, save local. Available for Carnegie residents.</p>
      </div>
    </div>
  </section>

  <!-- Personalized Fitting Section -->
  <section class="max-w-screen-2xl mx-auto px-8 md:px-12 mb-32">
    <div class="bg-on-background p-12 md:p-24 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="z-10 max-w-2xl">
        <h2 class="font-headline text-5xl md:text-6xl font-black text-surface tracking-tighter leading-none mb-8">
            PRECISION <br/><span class="text-primary">FOOTWEAR FITTING</span>
        </h2>
        <p class="text-surface-variant font-body text-xl md:text-2xl font-medium leading-relaxed">
            Each customer gets an attentive and personalised service from our highly qualified shoe fitters.
        </p>
        <div class="mt-12">
          <a href="/contact" class="bg-primary text-on-primary font-headline font-bold px-10 py-5 uppercase tracking-tighter hover:bg-stone-800 transition-all rounded-lg inline-block">Book a Fitting</a>
        </div>
      </div>
      <div class="w-full md:w-2/5 aspect-[4/5] bg-surface-container-low rounded-lg -rotate-1 shadow-2xl relative z-10 overflow-hidden">
        <img loading="lazy" decoding="async" class="w-full h-full object-cover" alt="Professional shoe fitting" src="/home_fitting.jpg"/>
      </div>
      <!-- Decorative element -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary opacity-10 blur-[120px] -mr-48 -mt-48"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-tertiary opacity-10 blur-[100px] -ml-32 -mb-32"></div>
    </div>
  </section>
</Layout>
