---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Our Brands | Carnegie Shoes" description="Browse our curated footprint of quality shoes. Discover Merrell, Skechers, Propet and more at Carnegie Shoes in Melbourne.">
  <!-- Page Header -->
  <header class="px-8 mb-16 max-w-screen-2xl mx-auto">
    <h1 class="font-headline text-7xl md:text-9xl font-black tracking-tighter uppercase leading-[0.8] mb-6">
        The <span class="text-primary">Curated</span> <br/>Portfolio.
    </h1>
    <p class="font-body text-xl text-on-surface-variant max-w-2xl">
        We bridge the gap between global innovation and local comfort, hand-selecting every brand for its unique contribution to footwear excellence.
    </p>
  </header>

  <!-- Section 1: Performance & Active -->
  <section class="px-8 mb-24 max-w-screen-2xl mx-auto">
    <div class="flex flex-col md:flex-row gap-12 items-end mb-12">
      <div class="flex-1">
        <span class="font-label text-sm tracking-[0.3em] uppercase text-primary font-bold mb-4 block">01 / Motion</span>
        <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter uppercase">Performance & Active</h2>
      </div>
      <p class="font-body text-on-surface-variant max-w-md pb-2">Technical silhouettes engineered for those who move. High-impact support meets breathable innovation.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-4 h-[500px]">
        <img loading="lazy" decoding="async" class="w-full h-full object-cover rounded-xl shadow-2xl" alt="Vibrant sneakers" src="/images/IMG_3779.jpeg"/>
      </div>
      <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-primary text-on-primary p-8 rounded-xl flex flex-col justify-between group hover:scale-[1.02] transition-transform cursor-pointer">
          <div class="font-headline text-4xl font-black tracking-tighter">MERRELL</div>
          <p class="font-label text-xs uppercase tracking-widest mt-4 opacity-80">Rugged Outdoor Tech</p>
          <span class="material-symbols-outlined self-end text-3xl mt-8" aria-hidden="true">arrow_outward</span>
        </div>
        <div class="bg-surface-variant p-8 rounded-xl flex flex-col justify-between group hover:scale-[1.02] transition-transform cursor-pointer">
          <div class="font-headline text-4xl font-black tracking-tighter text-on-background">SKECHERS</div>
          <p class="font-label text-xs uppercase tracking-widest mt-4 text-on-surface-variant">Daily Athletic Comfort</p>
          <span class="material-symbols-outlined self-end text-3xl mt-8 text-primary" aria-hidden="true">arrow_outward</span>
        </div>
        <div class="bg-tertiary text-on-tertiary p-8 rounded-xl flex flex-col justify-between group hover:scale-[1.02] transition-transform cursor-pointer">
          <div class="font-headline text-4xl font-black tracking-tighter">SAUCONY</div>
          <p class="font-label text-xs uppercase tracking-widest mt-4 opacity-80">Elite Running Power</p>
          <span class="material-symbols-outlined self-end text-3xl mt-8" aria-hidden="true">arrow_outward</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Comfort -->
  <section class="bg-on-background py-24 mb-24 text-surface">
    <div class="px-8 max-w-screen-2xl mx-auto">
      <div class="flex flex-col md:flex-row gap-12 items-end mb-16">
        <div class="flex-1">
          <span class="font-label text-sm tracking-[0.3em] uppercase text-primary font-bold mb-4 block">02 / Daily</span>
          <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter uppercase">The Comfort Edit</h2>
        </div>
        <p class="font-body text-surface-variant max-w-md pb-2">Global craftsmanship curated for all-day wear. Soft leathers, ergonomic soles, and timeless European aesthetics.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="md:col-span-2 bg-surface p-12 rounded-xl text-on-background flex items-center gap-8 overflow-hidden relative group">
          <div class="relative z-10">
            <div class="font-headline text-6xl font-black tracking-tighter mb-4">ARA</div>
            <p class="font-body text-on-surface-variant">German precision meet contemporary fashion. High-soft technology in every step.</p>
          </div>
          <img loading="lazy" decoding="async" class="w-48 h-48 object-cover absolute -right-4 -bottom-4 opacity-20 group-hover:opacity-100 group-hover:-translate-y-4 transition-all duration-500" alt="Ara shoes" src="/images/IMG_3782.jpeg"/>
        </div>
        <div class="grid grid-cols-2 gap-4 md:col-span-2">
          <div class="bg-secondary p-8 rounded-xl flex flex-col justify-center text-center hover:bg-primary transition-colors cursor-pointer text-white">
            <div class="font-headline text-2xl font-black tracking-tighter">RIEKER</div>
            <span class="font-label text-[10px] uppercase mt-2 opacity-70">Anti-stress</span>
          </div>
          <div class="bg-tertiary text-white p-8 rounded-xl flex flex-col justify-center text-center hover:bg-primary transition-colors cursor-pointer">
            <div class="font-headline text-2xl font-black tracking-tighter">REMONTE</div>
            <span class="font-label text-[10px] uppercase mt-2 opacity-70">Premium Quality</span>
          </div>
          <div class="bg-surface-variant p-8 rounded-xl flex flex-col justify-center text-center text-on-background hover:bg-primary hover:text-white transition-all cursor-pointer">
            <div class="font-headline text-2xl font-black tracking-tighter">WONDERS</div>
            <span class="font-label text-[10px] uppercase mt-2 opacity-70">Made in Spain</span>
          </div>
          <div class="bg-primary text-white p-8 rounded-xl flex flex-col justify-center text-center hover:scale-105 transition-transform cursor-pointer">
            <div class="font-headline text-2xl font-black tracking-tighter">GABOR</div>
            <span class="font-label text-[10px] uppercase mt-2 opacity-70">Soft & Smart</span>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
        <div class="p-8 border border-outline-variant/30 rounded-xl hover:border-primary transition-colors group">
          <div class="font-headline text-3xl font-black tracking-tighter mb-2 group-hover:text-primary transition-colors">ECCO</div>
          <p class="font-body text-sm text-surface-variant">Danish design and world-class tanneries.</p>
        </div>
        <div class="p-8 border border-outline-variant/30 rounded-xl hover:border-primary transition-colors group">
          <div class="font-headline text-3xl font-black tracking-tighter mb-2 group-hover:text-primary transition-colors">ROCKPORT</div>
          <p class="font-body text-sm text-surface-variant">Walking comfort for the professional world.</p>
        </div>
        <div class="p-8 border border-outline-variant/30 rounded-xl hover:border-primary transition-colors group">
          <div class="font-headline text-3xl font-black tracking-tighter mb-2 group-hover:text-primary transition-colors">PITILLOS</div>
          <p class="font-body text-sm text-surface-variant">Classic elegance with modern cushioning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Medical/Orthotic Friendly -->
  <section class="px-8 mb-32 max-w-screen-2xl mx-auto">
    <div class="flex flex-col md:flex-row gap-12 items-end mb-12">
      <div class="flex-1">
        <span class="font-label text-sm tracking-[0.3em] uppercase text-primary font-bold mb-4 block">03 / Care</span>
        <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter uppercase">Medical Grade & <br/>Orthotic Friendly</h2>
      </div>
      <p class="font-body text-on-surface-variant max-w-md pb-2">Podiatry-approved solutions that never compromise on style. Designed for custom inserts and sensitive feet.</p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8 mb-16">
      <div class="relative group overflow-hidden rounded-2xl">
        <img loading="lazy" decoding="async" class="w-full h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-700" alt="Leather boots" src="/brands_clarks.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
        <div class="absolute bottom-12 left-12 right-12">
          <div class="inline-block bg-white text-primary px-3 py-1 font-label text-[10px] uppercase font-bold tracking-widest mb-4">The Iconic Standard</div>
          <h3 class="font-headline text-6xl font-black text-white tracking-tighter uppercase mb-4">CLARKS</h3>
          <p class="font-body text-white/90 max-w-xs mb-8">Legendary comfort and anatomical design that sets the industry standard.</p>
          <button class="bg-white text-on-background px-8 py-3 rounded-full font-label font-bold uppercase text-sm hover:bg-stone-200 transition-colors">View Collection</button>
        </div>
      </div>
      
      <div class="space-y-8">
        <div class="p-12 bg-primary-container rounded-2xl kinetic-border h-[calc(50%-1rem)] flex flex-col justify-center">
          <h3 class="font-headline text-4xl font-black text-on-primary-container tracking-tighter uppercase mb-4">PROPET</h3>
          <p class="font-body text-on-primary-container/80 text-lg mb-6">World-renowned for varied widths and specialized supportive footbeds.</p>
          <div class="flex items-center gap-4 text-on-primary-container font-label font-bold uppercase text-xs">
            <span class="w-12 h-[2px] bg-primary"></span> Deep Toe Boxes
          </div>
        </div>
        <div class="p-12 bg-surface-variant rounded-2xl border-l-8 border-tertiary h-[calc(50%-1rem)] flex flex-col justify-center">
          <h3 class="font-headline text-4xl font-black text-on-background tracking-tighter uppercase mb-4">SUREFIT</h3>
          <p class="font-body text-on-surface-variant text-lg mb-6">Smart anatomical shapes designed for growing feet and podiatric requirements.</p>
          <div class="flex items-center gap-4 text-on-background font-label font-bold uppercase text-xs">
            <span class="w-12 h-[2px] bg-tertiary"></span> Stability Control
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
