---
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.astro';
---

<Layout title="Services | Carnegie Shoes" description="Experience our precision shoe fitting and orthotics assessment services at Carnegie Shoes. We help babies, adults, and seniors walk in comfort.">
  <!-- Hero Section: Expressive Collage Header -->
  <section class="px-8 max-w-screen-2xl mx-auto mb-24 pb-20">
    <div class="relative">
      <div class="font-headline text-[clamp(3rem,12vw,8rem)] leading-[0.85] font-black uppercase tracking-tighter mb-4 text-primary">
          Every Step <br/>
          <span class="-webkit-text-stroke-[1px] -webkit-text-stroke-primary text-transparent">Matters.</span>
      </div>
      <div class="absolute top-0 right-0 hidden lg:block w-1/3 bg-tertiary-container p-8 -rotate-2 shadow-xl z-10">
        <p class="font-label text-on-tertiary-container text-lg tracking-widest font-bold">CARNEGIE SPECIALIZED CARE</p>
        <p class="text-on-tertiary-container mt-2">Personalized solutions for a vibrant, mobile community.</p>
      </div>
    </div>
  </section>

  <!-- Kinetic Mosaic Content Section -->
  <section class="px-8 max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
      <!-- Aged Care Package Card (Large, Asymmetric) -->
      <div class="col-span-12 md:col-span-7 bg-surface-container-low p-1 relative overflow-hidden group">
        <div class="relative h-full bg-surface-container-lowest p-8 md:p-12 flex flex-col justify-end min-h-[500px]">
          <img fetchpriority="high" decoding="async" alt="Professional care" class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale hover:grayscale-0 transition-all duration-700" src="/services_hero.jpg"/>
          <div class="relative z-10">
            <span class="inline-block bg-primary px-4 py-1 text-on-primary font-label text-sm mb-6">GOVERNMENT SUPPORTED</span>
            <h2 class="font-headline text-4xl md:text-6xl font-black uppercase tracking-tighter text-on-surface leading-none mb-6">
                We work with <br/>aged care package providers.
            </h2>
            <p class="max-w-md text-lg text-on-surface-variant mb-8">
                Navigating HCP and NDIS can be complex. We simplify the process to ensure you get the support you deserve.
            </p>
            <button class="flex items-center gap-2 font-label font-bold text-primary group-hover:gap-4 transition-all" aria-label="Learn more about government supported aged care packages">
                LEARN MORE <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Shoe Fitters Card (Smaller, Bold Color) -->
      <div class="col-span-12 md:col-span-5 bg-secondary-container p-12 flex flex-col justify-between">
        <div class="mb-12">
          <span class="material-symbols-outlined text-6xl text-on-secondary-container" aria-hidden="true" style="font-variation-settings: 'FILL' 1;">straighten</span>
        </div>
        <div>
          <h3 class="font-headline text-4xl font-bold uppercase tracking-tighter text-on-secondary-container leading-none mb-4">
              Experienced <br/>shoe fitters.
          </h3>
          <p class="text-on-secondary-container/80 font-medium">
              Our master fitters understand the unique anatomy of the foot. We don't just sell shoes; we measure for a lifetime of comfort.
          </p>
        </div>
      </div>
      
      <!-- Podiatrist Recommendations (Horizontal overlap) -->
      <div class="col-span-12 md:col-span-5 md:-mt-12 z-20 bg-tertiary p-12 text-on-tertiary">
        <h3 class="font-headline text-4xl font-bold uppercase tracking-tighter leading-none mb-6">
            Podiatrist <br/>recommendations.
        </h3>
        <ul class="space-y-4 font-body">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary-container" aria-hidden="true">check_circle</span>
            <span>Orthotic-friendly designs</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary-container" aria-hidden="true">check_circle</span>
            <span>Customized arch support fitting</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-tertiary-container" aria-hidden="true">check_circle</span>
            <span>Post-surgery recovery footwear</span>
          </li>
        </ul>
      </div>
      
      <!-- Multi-cultural Community (Image Heavy Collage) -->
      <div class="col-span-12 md:col-span-7 bg-surface-container-high overflow-hidden relative group">
        <div class="p-12 relative z-10 flex flex-col h-full justify-between min-h-[400px]">
          <div>
            <span class="font-label text-sm uppercase tracking-widest text-primary font-bold">Local Spirit</span>
            <h3 class="font-headline text-5xl font-black uppercase tracking-tighter text-on-surface-variant mt-2">
                Multi-cultural <br/>community.
            </h3>
          </div>
          <div class="flex gap-4">
            <div class="bg-white p-2 shadow-lg -rotate-3">
              <img loading="lazy" decoding="async" alt="Community event" class="w-32 h-32 object-cover" src="/services_community1.jpg"/>
            </div>
            <div class="bg-white p-2 shadow-lg rotate-6 mt-4">
              <img loading="lazy" decoding="async" alt="Community connection" class="w-32 h-32 object-cover" src="/services_community2.jpg"/>
            </div>
          </div>
        </div>
        <div class="absolute right-0 top-0 w-1/2 h-full bg-primary/10 -skew-x-12 translate-x-1/2"></div>
      </div>
    </div>
  </section>

  <CallToAction />
</Layout>
