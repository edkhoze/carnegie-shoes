---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { actions } from 'astro:actions';

const result = Astro.getActionResult(actions.contact);
const isSuccess = result?.data?.success;
const serverError = result?.error;

// Setup generic Turnstile testing keys if we want it to work without real keys in dev
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---

<Layout title="Contact Us | Carnegie Shoes" description="Get in touch with Carnegie Shoes for expert fitting advice. Visit our Koornang Road store in Melbourne or contact us online.">
  <!-- Hero Section -->
  <section class="max-w-screen-2xl mx-auto px-8 mb-20 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-0">
      <div class="md:col-span-8 bg-primary p-12 md:p-24 relative overflow-hidden">
        <h1 class="font-headline text-5xl md:text-8xl text-on-primary font-black tracking-tight leading-[0.9] mb-8 relative z-10">
            LET'S WALK<br>TOGETHER.
        </h1>
        <p class="text-on-primary/90 text-xl md:text-2xl max-w-lg font-medium leading-relaxed relative z-10">
            Whether you're looking for a bespoke fit or want to host a local community walk, our doors are always open.
        </p>
        <!-- Decorative block -->
        <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-secondary-container rotate-12 opacity-50"></div>
      </div>
      <div class="md:col-span-4 hidden md:block">
        <img alt="Carnegie Shoes flagship store interior" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMWi5FbZdC7mAmBreH1MhQClv0jjsPKoKKLf22Fi3I-qC0E0Uj-B5zrJQVUDp8QhbSAlThyIu5sKpS-wHkWkpV8fVydURUA5XrXg7ek08ciq-t1zz2wP-lImdvWDIXcUOMnWTFPWjTW6ohlDhvaklYXgINNRcXmKVo_cJwrKCNN_o48jGXUvHHEaqeCGoM2Zd-rDD97WGhznPQCrtVE7Xcog8HUGfDdsWFAqMJYqvZgL_ggIAkL_MhBOty95qMfl2J77BQyE7SSA">
      </div>
    </div>
  </section>

  <!-- Main Contact Grid -->
  <section class="max-w-screen-2xl mx-auto px-8 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <!-- Info Column (Asymmetric Grid Break) -->
      <div class="lg:col-span-5 grid grid-cols-1 gap-8">
        <!-- Location Card -->
        <div class="bg-surface-container-lowest p-10 group transition-all duration-300">
          <div class="flex items-start gap-6">
            <div class="bg-tertiary-container p-4 flex items-center justify-center">
              <span class="material-symbols-outlined text-tertiary text-3xl">location_on</span>
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-4 uppercase tracking-tighter">Our Store</h3>
              <address class="not-italic text-lg text-on-surface-variant font-medium leading-relaxed">
                <a href="https://share.google/pzjMnGaVlVBXVhT6j" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">148 Koornang Road,<br>Carnegie 3163</a>
              </address>
            </div>
          </div>
        </div>
        
        <!-- Connect Card -->
        <div class="bg-tertiary-container p-10">
          <h3 class="font-headline text-2xl font-bold mb-6 uppercase tracking-tighter text-on-tertiary-container">Direct Connect</h3>
          <div class="space-y-6">
            <div class="flex items-center gap-4 group">
              <span class="material-symbols-outlined text-tertiary font-bold">call</span>
              <a href="tel:0395691526" class="font-label font-bold tracking-widest text-lg hover:text-primary transition-colors">(03) 9569 1526</a>
            </div>
            <div class="flex items-center gap-4 group">
              <span class="material-symbols-outlined text-tertiary font-bold">mail</span>
              <a href="mailto:evagorelik@yahoo.com.au" class="font-label font-bold tracking-widest text-lg hover:text-primary transition-colors hover:underline">hello@carnegieshoes.com.au</a>
            </div>
          </div>
        </div>
        
        <!-- Hours Card -->
        <div class="bg-surface-container-low p-10">
          <h3 class="font-headline text-2xl font-bold mb-6 uppercase tracking-tighter">Availability</h3>
          <div class="space-y-4 font-label uppercase tracking-widest text-sm text-on-surface-variant">
            <div class="flex justify-between border-b-2 border-outline-variant/10 pb-2"><span>Tuesday - Friday</span><span class="font-bold text-on-surface">10 am - 5 pm</span></div>
            <div class="flex justify-between border-b-2 border-outline-variant/10 pb-2"><span>Sat — Sun</span><span class="font-bold text-on-surface">10 am - 4 pm</span></div>
            <div class="flex justify-between"><span>Monday</span><span class="font-bold text-primary">Closed</span></div>
          </div>
        </div>
        
        <!-- Map Placeholder -->
        <div class="h-64 bg-surface-variant overflow-hidden relative">
          <iframe 
            width="100%" 
            height="100%" 
            style="border:0;" 
            loading="lazy" 
            allowfullscreen 
            referrerpolicy="no-referrer-when-downgrade"
            src="https://maps.google.com/maps?q=148+Koornang+Road,+Carnegie,+VIC+3163,+Australia&t=&z=15&ie=UTF8&iwloc=&output=embed">
          </iframe>
        </div>
      </div>
      
      <!-- Form Column (Elevated Content) -->
      <div class="lg:col-span-7 bg-surface-container-lowest p-12 md:p-20 shadow-[0_48px_48px_-4px_rgba(0,0,0,0.06)] relative border-t-8 border-secondary">
        <div class="mb-12">
          <h2 class="font-headline text-4xl md:text-5xl font-black mb-4 uppercase tracking-tighter text-on-surface">Send a Signal</h2>
          <p class="text-on-surface-variant text-lg font-medium">We will get back to you as soon as we can</p>
        </div>

        {isSuccess ? (
          <div class="bg-tertiary-container/30 border-l-4 border-tertiary p-8 text-center mt-6">
            <div class="w-16 h-16 bg-tertiary text-white flex items-center justify-center mx-auto mb-4 text-3xl font-bold material-symbols-outlined">check</div>
            <h4 class="font-headline font-black uppercase tracking-tighter text-2xl text-on-surface mb-2">Signal Received</h4>
            <p class="text-on-surface-variant max-w-sm mx-auto">{result.data.message}</p>
          </div>
        ) : (
          <form method="POST" action={actions.contact} class="space-y-8">
            {serverError && (
              <div class="bg-error-container text-on-error-container p-4 border-l-4 border-error text-sm font-body">
                {serverError.message}
              </div>
            )}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label for="name" class="font-label text-xs font-bold uppercase tracking-widest text-secondary">Full Name</label>
                <input type="text" id="name" name="name" required class="w-full bg-surface-container-high border-none border-b-2 border-transparent focus:ring-0 focus:border-b-primary px-4 py-4 font-headline text-on-surface transition-all outline-none" placeholder="Your Name" />
              </div>
              
              <div class="space-y-2">
                <label for="email" class="font-label text-xs font-bold uppercase tracking-widest text-secondary">Email Address</label>
                <input type="email" id="email" name="email" required class="w-full bg-surface-container-high border-none border-b-2 border-transparent focus:ring-0 focus:border-b-primary px-4 py-4 font-headline text-on-surface transition-all outline-none" placeholder="hello@example.com" />
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="phone" class="font-label text-xs font-bold uppercase tracking-widest text-secondary">Phone (Optional)</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-surface-container-high border-none border-b-2 border-transparent focus:ring-0 focus:border-b-primary px-4 py-4 font-headline text-on-surface transition-all outline-none" placeholder="(03) 9569 1526" />
            </div>
            
            <div class="space-y-2">
              <label for="message" class="font-label text-xs font-bold uppercase tracking-widest text-secondary">Your Message</label>
              <textarea id="message" name="message" required class="w-full bg-surface-container-high border-none border-b-2 border-transparent focus:ring-0 focus:border-b-primary px-4 py-4 font-headline text-on-surface transition-all resize-none outline-none" placeholder="HOW CAN WE ASSIST YOUR JOURNEY?" rows="5"></textarea>
            </div>
            
            <div class="pt-2">
              <!-- Cloudflare Turnstile Widget -->
              <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>
            </div>
            
            <button type="submit" class="w-full bg-primary py-6 px-10 text-on-primary font-headline text-xl font-black uppercase tracking-tighter transition-all hover:bg-primary-dim active:scale-95 flex justify-between items-center group">
              <span>Submit Request</span>
              <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
            </button>
          </form>
        )}
      </div>
    </div>
  </section>
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</Layout>
