---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  structuredData?: any;
}

const {
  title,
  description = "Since 2014, Carnegie Shoes provides precision footwear fitting & orthotics. Durable, comfortable brands for infants, adults, and seniors.",
  structuredData
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = "https://carnegieshoes.com.au";
const canonicalURL = new URL(currentPath, siteUrl).href;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#E2583E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Carnegie Shoes" />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    )}

    <title>{title}</title>
  </head>
  <body>
    <Header />

    <div class="pt-32">
      <slot />
    </div>

    <Footer />



    {/* Lightweight conversion tracking: forwards tel/mailto/maps/form-submit events
        to Cloudflare Web Analytics (window.__cfBeacon.sendEvent) or any listener on
        `window.trackConversion`. No-ops gracefully if analytics hasn't loaded. */}
    <script is:inline>
      (function () {
        function track(name, detail) {
          try {
            if (typeof window.trackConversion === 'function') {
              window.trackConversion(name, detail);
            }
            if (window.__cfBeacon && typeof window.__cfBeacon.sendEvent === 'function') {
              window.__cfBeacon.sendEvent(name, detail);
            }
          } catch (_) { /* swallow */ }
        }

        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest && e.target.closest('a');
          if (!a) return;
          var href = a.getAttribute('href') || '';
          if (href.startsWith('tel:')) track('click_phone', { href: href });
          else if (href.startsWith('mailto:')) track('click_email', { href: href });
          else if (href.indexOf('maps.app.goo.gl') !== -1 || href.indexOf('maps.google') !== -1) track('click_directions', { href: href });
        }, { passive: true });

        document.addEventListener('submit', function (e) {
          var form = e.target;
          if (form && form.matches && form.matches('form[method="POST"]')) {
            track('submit_contact_form', { action: form.getAttribute('action') || '' });
          }
        }, { passive: true });
      })();
    </script>
  </body>
</html>
