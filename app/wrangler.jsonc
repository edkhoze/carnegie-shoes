{
	"compatibility_date": "2026-04-13",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "app",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"vars": {
		"FROM_EMAIL": "website@carnegieshoes.com.au",
		"TO_EMAIL": "evagorelik@yahoo.com.au"
	},
	"observability": {
		"enabled": true
	}
}